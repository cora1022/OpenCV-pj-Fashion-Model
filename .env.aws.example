# EC2 single-server Docker Compose deployment
# Copy this file to .env on the EC2 server:
#   cp .env.aws.example .env

# Public ports are handled by the Caddy service in docker-compose.yml.
# Open only 80 and 443 on the VPS/EC2 firewall.

# Frontend should call the same domain through Nginx.
# Leave empty so the built React app requests /api/... on the current origin.
VITE_API_BASE_URL=

# Qdrant runs inside Docker Compose. Do not expose 6333/6334 publicly.
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=naver_fashion_images_fashionclip

# MySQL runs inside Docker Compose. Do not expose 3306 publicly.
MYSQL_DATABASE=fashion_app
MYSQL_USER=fashion_user
MYSQL_PASSWORD=change-this-mysql-password
MYSQL_ROOT_PASSWORD=change-this-root-password
DATABASE_URL=mysql+pymysql://fashion_user:change-this-mysql-password@mysql:3306/fashion_app

# Backend model/search settings
FASHIONCLIP_MODEL_NAME=patrickjohncyh/fashion-clip
OPENCV_CROP_ENABLED=true
YOLO_CLOTHING_MODEL_PATH=backend/models/yolov8n-clothing-detection-best.pt
YOLO_CONFIDENCE=0.25

# Gemini feature summary. Leave empty to disable Gemini analysis.
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=20

# Auth
# Generate a strong value, for example:
#   openssl rand -hex 32
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Format:
# username:display_name:bcrypt_hash,username2:display_name2:bcrypt_hash2
# Generate bcrypt hashes locally:
# python -c "from backend.app.core.security import hash_password; print(hash_password('your-password'))"
ADMIN_USERS=

# Same-domain Caddy/Nginx proxy means CORS is usually not important in production.
# Put your real domain here after DNS is connected.
# Example: CORS_ORIGINS=https://coran1022.com,https://www.coran1022.com
CORS_ORIGINS=https://coran1022.com,https://www.coran1022.com

# Future extension placeholders. Not used for this EC2 single-server setup.
STORAGE_BACKEND=local
S3_BUCKET_NAME=
S3_REGION=
