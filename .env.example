QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=naver_fashion_images_fashionclip

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

FASHIONCLIP_MODEL_NAME=patrickjohncyh/fashion-clip
OPENCV_CROP_ENABLED=true
YOLO_CLOTHING_MODEL_PATH=backend/models/yolov8n-clothing-detection-best.pt
YOLO_CONFIDENCE=0.25

GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=20

MYSQL_DATABASE=fashion_app
MYSQL_USER=fashion_user
MYSQL_PASSWORD=fashion_password
MYSQL_ROOT_PASSWORD=fashion_root_password

# Local host example:
# DATABASE_URL=mysql+pymysql://fashion_user:fashion_password@localhost:3307/fashion_app
# Docker Compose internal example:
DATABASE_URL=mysql+pymysql://fashion_user:fashion_password@mysql:3306/fashion_app

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Format: username:display_name:bcrypt_hash,username2:display_name2:bcrypt_hash2
# Generate hashes with: python -c "from backend.app.core.security import hash_password; print(hash_password('your-password'))"
ADMIN_USERS=

STORAGE_BACKEND=local
S3_BUCKET_NAME=
S3_REGION=

CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
